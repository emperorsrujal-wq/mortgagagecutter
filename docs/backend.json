
{
  "entities": {
    "Lead": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lead",
      "type": "object",
      "description": "Represents a potential customer who has submitted their information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the lead, typically the Firebase Auth UID."
        },
        "name": {
          "type": "string",
          "description": "Name of the lead."
        },
        "email": {
          "type": "string",
          "description": "Email address of the lead.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the lead."
        },
        "submissionDate": {
          "type": "string",
          "description": "Date and time the lead information was submitted.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "submissionDate"
      ]
    },
    "Mail": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Mail",
      "type": "object",
      "description": "Document written to trigger the Firebase Trigger Email extension.",
      "properties": {
        "to": { "type": "string" },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "html": { "type": "string" }
          }
        }
      },
      "required": ["to", "message"]
    },
    "MortgageQuestionnaireResponse": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MortgageQuestionnaireResponse",
      "type": "object",
      "description": "Represents a user's response to the mortgage questionnaire.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the questionnaire response."
        },
        "leadId": {
          "type": "string",
          "description": "Reference to the Lead who submitted the questionnaire. (Relationship: Lead 1:1 MortgageQuestionnaireResponse)"
        },
        "currentMortgageBalance": {
          "type": "number",
          "description": "The user's current mortgage balance."
        },
        "currentInterestRate": {
          "type": "number",
          "description": "The user's current interest rate."
        },
        "originalLoanAmount": {
          "type": "number",
          "description": "The original loan amount."
        },
        "loanTerm": {
          "type": "number",
          "description": "The loan term in years."
        },
        "monthlyMortgagePayment": {
          "type": "number",
          "description": "The user's monthly mortgage payment (principal & interest)."
        },
        "yearsInHome": {
          "type": "number",
          "description": "Number of years the user has been in their home."
        },
        "estimatedHomeValue": {
          "type": "number",
          "description": "Estimated home value (optional)."
        }
      },
      "required": [
        "id",
        "leadId",
        "currentMortgageBalance",
        "currentInterestRate",
        "originalLoanAmount",
        "loanTerm",
        "monthlyMortgagePayment",
        "yearsInHome"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "apple.com",
      "phone",
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/leads/{leadId}",
        "definition": {
          "entityName": "Lead",
          "schema": {
            "$ref": "#/backend/entities/Lead"
          },
          "description": "Stores lead information."
        }
      },
      {
        "path": "/mail/{mailId}",
        "definition": {
          "entityName": "Mail",
          "schema": {
            "$ref": "#/backend/entities/Mail"
          },
          "description": "Collection for triggering outgoing emails."
        }
      }
    ],
    "reasoning": "Standard structure for lead capture and email automation."
  }
}

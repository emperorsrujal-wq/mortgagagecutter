
{
  "entities": {
    "Lead": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lead",
      "type": "object",
      "description": "Represents a potential customer who has submitted their information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the lead, typically the Firebase Auth UID."
        },
        "name": {
          "type": "string",
          "description": "Name of the lead."
        },
        "email": {
          "type": "string",
          "description": "Email address of the lead.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the lead."
        },
        "submissionDate": {
          "type": "string",
          "description": "Date and time the lead information was submitted.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "submissionDate"
      ]
    },
    "Mail": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Mail",
      "type": "object",
      "description": "Document written to trigger the Firebase Trigger Email extension.",
      "properties": {
        "to": { "type": "string" },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "html": { "type": "string" }
          }
        }
      },
      "required": ["to", "message"]
    },
    "BankScreenerResponse": {
      "title": "BankScreenerResponse",
      "description": "Stored data from the HELOC Bank Screener questionnaire.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bankName": { "type": "string" },
        "formData": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChunkerState": {
      "title": "ChunkerState",
      "description": "Saved inputs for the HELOC-Assist Chunker Estimator.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "inputs": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "apple.com",
      "phone",
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/leads/{leadId}",
        "definition": {
          "entityName": "Lead",
          "schema": {
            "$ref": "#/backend/entities/Lead"
          },
          "description": "Stores lead information."
        }
      },
      {
        "path": "/mail/{mailId}",
        "definition": {
          "entityName": "Mail",
          "schema": {
            "$ref": "#/backend/entities/Mail"
          },
          "description": "Collection for triggering outgoing emails."
        }
      },
      {
        "path": "/leads/{leadId}/bankScreeners/{screenerId}",
        "definition": {
          "entityName": "BankScreenerResponse",
          "schema": { "$ref": "#/backend/entities/BankScreenerResponse" },
          "description": "User's saved bank screener data."
        }
      },
      {
        "path": "/leads/{leadId}/chunkerStates/{stateId}",
        "definition": {
          "entityName": "ChunkerState",
          "schema": { "$ref": "#/backend/entities/ChunkerState" },
          "description": "User's saved chunker estimator inputs."
        }
      }
    ],
    "reasoning": "Standard structure for lead capture and personalized member tools."
  }
}

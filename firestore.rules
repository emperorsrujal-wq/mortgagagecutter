
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      allow create: if request.auth != null && request.auth.uid == leadId;
      allow get: if request.auth != null && request.auth.uid == leadId;
      allow list: if false;
      allow update: if request.auth != null && request.auth.uid == leadId;
      
      match /bankScreeners/{screenerId} {
        allow read, write: if request.auth != null && request.auth.uid == leadId;
      }
      
      match /chunkerStates/{stateId} {
        allow read, write: if request.auth != null && request.auth.uid == leadId;
      }
    }

    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    match /leads/{leadId}/{allSubcollections=**} {
      allow read, write: if request.auth != null && request.auth.uid == leadId;
    }
  }
}

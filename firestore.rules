rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /leads/{leadId} collection.
     * @path /leads/{leadId}
     * @allow (create) Signed-in user can create a lead document if the leadId matches their UID.
     * @allow (get, list, update, delete) Signed-in user can access their own lead document.
     * @deny (create) Signed-in user cannot create a lead document if the leadId does not match their UID.
     * @principle Enforces document ownership for all operations.
     */
    match /leads/{leadId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

      // Helper function to check if the user is the owner of the existing document.
      function isExistingOwner(leadId) {
        return request.auth.uid == resource.data.uid;
      }

      // Read rules
      allow get: if isSignedIn() && isOwner(leadId);
      allow list: if isSignedIn() && request.auth.uid == leadId;

      // Write rules
      allow create: if isSignedIn() && request.auth.uid == leadId;
      allow update: if isSignedIn() && isExistingOwner(leadId);
      allow delete: if isSignedIn() && isExistingOwner(leadId);
    }

    /**
     * @description Controls access to the /leads/{leadId}/mortgage_questionnaire_response/{responseId} collection.
     * @path /leads/{leadId}/mortgage_questionnaire_response/{responseId}
     * @allow (create) Signed-in user can create a mortgage questionnaire response document under their lead document.
     * @allow (get, list, update, delete) Signed-in user can access their own mortgage questionnaire response document.
     * @deny (create) Signed-in user cannot create a mortgage questionnaire response document under another user's lead document.
     * @principle Enforces document ownership for all operations.
     */
    match /leads/{leadId}/mortgage_questionnaire_response/{responseId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the parent lead document.
      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

        // Helper function to check if the user is the owner of the existing document.
      function isExistingOwner(leadId) {
        return request.auth.uid == get(/databases/$(database)/documents/leads/$(leadId)).data.uid;
      }

      // Read rules
      allow get: if isSignedIn() && isOwner(leadId);
      allow list: if isSignedIn() && isOwner(leadId);

      // Write rules
      allow create: if isSignedIn() && isOwner(leadId);
      allow update: if isSignedIn() && isExistingOwner(leadId);
      allow delete: if isSignedIn() && isExistingOwner(leadId);
    }

    /**
     * @description Controls access to the /leads/{leadId}/purchases/{purchaseId} collection.
     * @path /leads/{leadId}/purchases/{purchaseId}
     * @allow (create) Signed-in user can create a purchase document under their lead document.
     * @allow (get, list, update, delete) Signed-in user can access their own purchase document.
     * @deny (create) Signed-in user cannot create a purchase document under another user's lead document.
     * @principle Enforces document ownership for all operations.
     */
    match /leads/{leadId}/purchases/{purchaseId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the parent lead document.
      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

        // Helper function to check if the user is the owner of the existing document.
      function isExistingOwner(leadId) {
        return request.auth.uid == get(/databases/$(database)/documents/leads/$(leadId)).data.uid;
      }

      // Read rules
      allow get: if isSignedIn() && isOwner(leadId);
      allow list: if isSignedIn() && isOwner(leadId);

      // Write rules
      allow create: if isSignedIn() && isOwner(leadId);
      allow update: if isSignedIn() && isExistingOwner(leadId);
      allow delete: if isSignedIn() && isExistingOwner(leadId);
    }

    /**
     * @description Controls access to the /leads/{leadId}/savings_reports/{reportId} collection.
     * @path /leads/{leadId}/savings_reports/{reportId}
     * @allow (create) Signed-in user can create a savings report document under their lead document.
     * @allow (get, list, update, delete) Signed-in user can access their own savings report document.
     * @deny (create) Signed-in user cannot create a savings report document under another user's lead document.
     * @principle Enforces document ownership for all operations.
     */
    match /leads/{leadId}/savings_reports/{reportId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the parent lead document.
      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

      // Helper function to check if the user is the owner of the existing document.
      function isExistingOwner(leadId) {
        return request.auth.uid == get(/databases/$(database)/documents/leads/$(leadId)).data.uid;
      }

      // Read rules
      allow get: if isSignedIn() && isOwner(leadId);
      allow list: if isSignedIn() && isOwner(leadId);

      // Write rules
      allow create: if isSignedIn() && isOwner(leadId);
      allow update: if isSignedIn() && isExistingOwner(leadId);
      allow delete: if isSignedIn() && isExistingOwner(leadId);
    }

    /**
     * @description Controls access to the /leads/{leadId}/user_authentications/{authId} collection.
     * @path /leads/{leadId}/user_authentications/{authId}
     * @allow (create) Signed-in user can create a user authentication document under their lead document.
     * @allow (get, list, update, delete) Signed-in user can access their own user authentication document.
     * @deny (create) Signed-in user cannot create a user authentication document under another user's lead document.
     * @principle Enforces document ownership for all operations.
     */
    match /leads/{leadId}/user_authentications/{authId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the parent lead document.
      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

      // Helper function to check if the user is the owner of the existing document.
      function isExistingOwner(leadId) {
        return request.auth.uid == get(/databases/$(database)/documents/leads/$(leadId)).data.uid;
      }

      // Read rules
      allow get: if isSignedIn() && isOwner(leadId);
      allow list: if isSignedIn() && isOwner(leadId);

      // Write rules
      allow create: if isSignedIn() && isOwner(leadId);
      allow update: if isSignedIn() && isExistingOwner(leadId);
      allow delete: if isSignedIn() && isExistingOwner(leadId);
    }
  }
}
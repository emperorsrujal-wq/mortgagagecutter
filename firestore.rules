/**
 * @fileOverview
 * This ruleset enforces a strict user-ownership model for all data, where each lead and their associated data can only be accessed by the authenticated user corresponding to that lead.
 *
 * Data Structure:
 * All data is nested under the /leads/{leadId} collection. Subcollections are used to store related data:
 * - /leads/{leadId}/mortgage_questionnaire_response/{responseId}
 * - /leads/{leadId}/purchases/{purchaseId}
 * - /leads/{leadId}/savings_reports/{reportId}
 * - /leads/{leadId}/user_authentications/{authId}
 *
 * Key Security Decisions:
 * - Listing leads is generally disallowed to prevent information leakage, except for the authenticated lead user themselves.
 * - All write operations are restricted to the owner (the authenticated lead) only.
 * - Data consistency is enforced by validating that the `leadId` in subcollection documents matches the `leadId` in the path.
 * - To simplify authorization, the `leadId` is used directly in the path and is validated against `request.auth.uid` during write operations. This avoids the need for complex `get()` calls to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the leads collection.  Allows a lead to create their own record.
     * @path /leads/{leadId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create a lead document with ID 'user_abc'.
     * @deny (create) - Authenticated user with UID 'user_abc' cannot create a lead document with ID 'user_xyz'.
     * @allow (get, list) - Authenticated user can read their own profile.
     * @deny (get, list) - Unauthenticated user or another authenticated user cannot access this.
     * @allow (update, delete) - Authenticated user can update their own profile.
     * @deny (update, delete) - Unauthenticated user or another authenticated user cannot modify.
     * @principle Enforces document ownership for all operations.
     */
    match /leads/{leadId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId);
      allow update: if isExistingOwner(leadId);
      allow delete: if isExistingOwner(leadId);
    }

    /**
     * @description Controls access to mortgage questionnaire responses for a given lead. Only the lead can create, read, update, and delete their own responses.
     * @path /leads/{leadId}/mortgage_questionnaire_response/{responseId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create a mortgage questionnaire response under lead 'user_abc'.
     * @deny (create) - Authenticated user with UID 'user_abc' cannot create a mortgage questionnaire response under lead 'user_xyz'.
     * @allow (get, list) - Authenticated user can read their own mortgage questionnaire response.
     * @deny (get, list) - Unauthenticated user or another authenticated user cannot access this.
     * @allow (update, delete) - Authenticated user can update their own mortgage questionnaire response.
     * @deny (update, delete) - Unauthenticated user or another authenticated user cannot modify.
     * @principle Enforces document ownership and relational integrity.
     */
    match /leads/{leadId}/mortgage_questionnaire_response/{responseId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.leadId == leadId;
      allow delete: if isExistingOwner(leadId);
    }

    /**
     * @description Controls access to purchase information for a given lead. Only the lead can create, read, update, and delete their own purchase records.
     * @path /leads/{leadId}/purchases/{purchaseId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create a purchase record under lead 'user_abc'.
     * @deny (create) - Authenticated user with UID 'user_abc' cannot create a purchase record under lead 'user_xyz'.
     * @allow (get, list) - Authenticated user can read their own purchase record.
     * @deny (get, list) - Unauthenticated user or another authenticated user cannot access this.
     * @allow (update, delete) - Authenticated user can update their own purchase record.
     * @deny (update, delete) - Unauthenticated user or another authenticated user cannot modify.
     * @principle Enforces document ownership and relational integrity.
     */
    match /leads/{leadId}/purchases/{purchaseId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.leadId == leadId;
      allow delete: if isExistingOwner(leadId);
    }

    /**
     * @description Controls access to savings reports for a given lead. Only the lead can create, read, update, and delete their own savings reports.
     * @path /leads/{leadId}/savings_reports/{reportId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create a savings report under lead 'user_abc'.
     * @deny (create) - Authenticated user with UID 'user_abc' cannot create a savings report under lead 'user_xyz'.
     * @allow (get, list) - Authenticated user can read their own savings report.
     * @deny (get, list) - Unauthenticated user or another authenticated user cannot access this.
     * @allow (update, delete) - Authenticated user can update their own savings report.
     * @deny (update, delete) - Unauthenticated user or another authenticated user cannot modify.
     * @principle Enforces document ownership and relational integrity.
     */
    match /leads/{leadId}/savings_reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.leadId == leadId;
      allow delete: if isExistingOwner(leadId);
    }

    /**
     * @description Controls access to user authentication information for a given lead. Only the lead can create, read, update, and delete their own authentication records.
     * @path /leads/{leadId}/user_authentications/{authId}
     * @allow (create) - Authenticated user with UID 'user_abc' can create a user authentication record under lead 'user_abc'.
     * @deny (create) - Authenticated user with UID 'user_abc' cannot create a user authentication record under lead 'user_xyz'.
     * @allow (get, list) - Authenticated user can read their own user authentication record.
     * @deny (get, list) - Unauthenticated user or another authenticated user cannot access this.
     * @allow (update, delete) - Authenticated user can update their own user authentication record.
     * @deny (update, delete) - Unauthenticated user or another authenticated user cannot modify.
     * @principle Enforces document ownership and relational integrity.
     */
    match /leads/{leadId}/user_authentications/{authId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.leadId == leadId;
      allow delete: if isExistingOwner(leadId);
    }
  }
}
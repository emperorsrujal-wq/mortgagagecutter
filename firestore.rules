rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects the top-level /leads collection, allowing only authenticated users to create a lead document with their own ID, and preventing listing for non-admins.
     * @path /leads/{leadId}
     * @allow (create) - Authenticated user creates a lead document where leadId matches their auth.uid.
     *   Request: auth.uid = "user123", request.resource.data.id = "user123"
     * @deny (create) - Authenticated user tries to create a lead document with an ID that doesn't match their auth.uid.
     *   Request: auth.uid = "user123", request.resource.data.id = "differentUser"
     * @deny (list) - Any user attempts to list all leads.
     *   Request: N/A (list operation doesn't have request data)
     * @principle Enforces document ownership for writes and disables listing for non-admins.
     */
    match /leads/{leadId} {
      // Helper function to check if the request is made by the owner of the lead.
      function isOwner(leadId) {
        return request.auth != null && request.auth.uid == leadId;
      }

      // Helper function to check if the document exists and is owned by the user.
      function isExistingOwner(leadId) {
        return isOwner(leadId) && exists(/databases/$(database)/documents/leads/$(leadId));
      }

      // Allow a user to create a lead document with their own ID.
      allow create: if request.auth != null && leadId == request.auth.uid;

      // Allow a user to get their own lead document.
      allow get: if isOwner(leadId);

      // Prevent listing all leads.
      allow list: if false;

      // Allow a user to update their own lead document. Enforce immutability of the leadId.
      allow update: if isOwner(leadId);

      // Allow a user to delete their own lead document.
      allow delete: if isOwner(leadId);
    }

    /**
     * @description Protects the /leads/{leadId}/mortgage_questionnaire_response/{responseId} collection, enforcing that only the lead owner can create, read, update, or delete responses.
     * @path /leads/{leadId}/mortgage_questionnaire_response/{responseId}
     * @allow (create) - Authenticated user creates a response under their lead.
     *   Request: auth.uid = "user123", path = "/leads/user123/mortgage_questionnaire_response/response1"
     * @deny (create) - Authenticated user tries to create a response under someone else's lead.
     *   Request: auth.uid = "user123", path = "/leads/differentUser/mortgage_questionnaire_response/response1"
     * @deny (update) - Authenticated user tries to update a response under someone else's lead.
     *   Request: auth.uid = "user123", path = "/leads/differentUser/mortgage_questionnaire_response/response1"
     * @principle Restricts access to a user's own data tree.
     */
    match /leads/{leadId}/mortgage_questionnaire_response/{responseId} {
      // Reuse the isOwner function defined above.

      // Allow a user to create a mortgage questionnaire response under their lead.
      allow create: if request.auth != null && leadId == request.auth.uid;

      // Allow a user to get a mortgage questionnaire response under their lead.
      allow get: if isOwner(leadId);

      // Allow a user to list mortgage questionnaire responses under their lead.
      allow list: if isOwner(leadId);

      // Allow a user to update a mortgage questionnaire response under their lead.
      allow update: if isOwner(leadId);

      // Allow a user to delete a mortgage questionnaire response under their lead.
      allow delete: if isOwner(leadId);
    }

    /**
     * @description Protects the /leads/{leadId}/purchases/{purchaseId} collection, enforcing that only the lead owner can create, read, update, or delete purchases.
     * @path /leads/{leadId}/purchases/{purchaseId}
     * @allow (create) - Authenticated user creates a purchase under their lead.
     *   Request: auth.uid = "user123", path = "/leads/user123/purchases/purchase1"
     * @deny (create) - Authenticated user tries to create a purchase under someone else's lead.
     *   Request: auth.uid = "user123", path = "/leads/differentUser/purchases/purchase1"
     * @principle Restricts access to a user's own data tree.
     */
    match /leads/{leadId}/purchases/{purchaseId} {
      // Reuse the isOwner function defined above.

      // Allow a user to create a purchase under their lead.
      allow create: if request.auth != null && leadId == request.auth.uid;

      // Allow a user to get a purchase under their lead.
      allow get: if isOwner(leadId);

      // Allow a user to list purchases under their lead.
      allow list: if isOwner(leadId);

      // Allow a user to update a purchase under their lead.
      allow update: if isOwner(leadId);

      // Allow a user to delete a purchase under their lead.
      allow delete: if isOwner(leadId);
    }

    /**
     * @description Protects the /leads/{leadId}/savings_reports/{reportId} collection, enforcing that only the lead owner can create, read, update, or delete savings reports.
     * @path /leads/{leadId}/savings_reports/{reportId}
     * @allow (create) - Authenticated user creates a savings report under their lead.
     *   Request: auth.uid = "user123", path = "/leads/user123/savings_reports/report1"
     * @deny (create) - Authenticated user tries to create a savings report under someone else's lead.
     *   Request: auth.uid = "user123", path = "/leads/differentUser/savings_reports/report1"
     * @principle Restricts access to a user's own data tree.
     */
    match /leads/{leadId}/savings_reports/{reportId} {
      // Reuse the isOwner function defined above.

      // Allow a user to create a savings report under their lead.
      allow create: if request.auth != null && leadId == request.auth.uid;

      // Allow a user to get a savings report under their lead.
      allow get: if isOwner(leadId);

      // Allow a user to list savings reports under their lead.
      allow list: if isOwner(leadId);

      // Allow a user to update a savings report under their lead.
      allow update: if isOwner(leadId);

      // Allow a user to delete a savings report under their lead.
      allow delete: if isOwner(leadId);
    }

    /**
     * @description Protects the /leads/{leadId}/user_authentications/{authId} collection, enforcing that only the lead owner can create, read, update, or delete authentication records.
     * @path /leads/{leadId}/user_authentications/{authId}
     * @allow (create) - Authenticated user creates a user authentication under their lead.
     *   Request: auth.uid = "user123", path = "/leads/user123/user_authentications/auth1"
     * @deny (create) - Authenticated user tries to create a user authentication under someone else's lead.
     *   Request: auth.uid = "user123", path = "/leads/differentUser/user_authentications/auth1"
     * @principle Restricts access to a user's own data tree.
     */
    match /leads/{leadId}/user_authentications/{authId} {
      // Reuse the isOwner function defined above.

      // Allow a user to create a user authentication under their lead.
      allow create: if request.auth != null && leadId == request.auth.uid;

      // Allow a user to get a user authentication under their lead.
      allow get: if isOwner(leadId);

      // Allow a user to list user authentications under their lead.
      allow list: if isOwner(leadId);

      // Allow a user to update a user authentication under their lead.
      allow update: if isOwner(leadId);

      // Allow a user to delete a user authentication under their lead.
      allow delete: if isOwner(leadId);
    }
  }
}
/**
 * @description This ruleset enforces a strict user-ownership model for all data. Each lead can only access their own information.
 * Data is organized under the /leads/{leadId} path, with subcollections for related data.
 * @dataStructure
 * - /leads/{leadId}: Stores lead information, with leadId matching the authenticated user's UID.
 * - /leads/{leadId}/mortgage_questionnaire_response/{responseId}: Stores mortgage questionnaire responses for a specific lead.
 * - /leads/{leadId}/purchases/{purchaseId}: Stores purchase information for a specific lead.
 * - /leads/{leadId}/savings_reports/{reportId}: Stores savings reports for a specific lead.
 * - /leads/{leadId}/user_authentications/{authId}: Stores user authentication details for a specific lead.
 * @keySecurityDecisions
 * - Users can only create their own lead document (self-registration).
 * - Users can only read and write data within their own /leads/{leadId} data tree.
 * - Listing leads is disallowed to prevent unauthorized data access.
 * - Relational integrity is enforced to ensure that leadId within subcollection documents always matches the leadId in the path.
 * @denormalizationForAuthorization N/A - Path-based ownership is used for authorization.
 * @structuralSegregation N/A - All data is private and user-specific.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /leads/{leadId} collection, allowing users to create their own lead document and manage their own data.
     * @path /leads/{leadId}
     * @allow (create) User with UID 'user_abc' can create a lead document with ID 'user_abc'.
     * @deny (create) User with UID 'user_def' cannot create a lead document with ID 'user_abc'.
     * @allow (get, update, delete) User with UID 'user_abc' can get, update, and delete the lead document with ID 'user_abc'.
     * @deny (get, update, delete) User with UID 'user_def' cannot get, update, or delete the lead document with ID 'user_abc'.
     * @principle Enforces document ownership for writes.
     */
    match /leads/{leadId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if false;
      allow create: if isOwner(leadId);
      allow update: if isExistingOwner(leadId);
      allow delete: if isExistingOwner(leadId);
    }

    /**
     * @description Controls access to the /leads/{leadId}/mortgage_questionnaire_response/{responseId} subcollection, restricting access to the lead owner.
     * @path /leads/{leadId}/mortgage_questionnaire_response/{responseId}
     * @allow (create) User with UID 'user_abc' can create a mortgage questionnaire response document under /leads/user_abc/.
     * @deny (create) User with UID 'user_def' cannot create a mortgage questionnaire response document under /leads/user_abc/.
     * @allow (get, update, delete) User with UID 'user_abc' can get, update, and delete the mortgage questionnaire response document under /leads/user_abc/.
     * @deny (get, update, delete) User with UID 'user_def' cannot get, update, or delete the mortgage questionnaire response document under /leads/user_abc/.
     * @principle Restricts access to a user's own data tree. Validates relational integrity between documents.
     */
    match /leads/{leadId}/mortgage_questionnaire_response/{responseId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

       function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.leadId == leadId;
      allow delete: if isExistingOwner(leadId);
    }

    /**
     * @description Controls access to the /leads/{leadId}/purchases/{purchaseId} subcollection, restricting access to the lead owner.
     * @path /leads/{leadId}/purchases/{purchaseId}
     * @allow (create) User with UID 'user_abc' can create a purchase document under /leads/user_abc/.
     * @deny (create) User with UID 'user_def' cannot create a purchase document under /leads/user_abc/.
     * @allow (get, update, delete) User with UID 'user_abc' can get, update, and delete the purchase document under /leads/user_abc/.
     * @deny (get, update, delete) User with UID 'user_def' cannot get, update, or delete the purchase document under /leads/user_abc/.
     * @principle Restricts access to a user's own data tree. Validates relational integrity between documents.
     */
    match /leads/{leadId}/purchases/{purchaseId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

       function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.leadId == leadId;
      allow delete: if isExistingOwner(leadId);
    }

    /**
     * @description Controls access to the /leads/{leadId}/savings_reports/{reportId} subcollection, restricting access to the lead owner.
     * @path /leads/{leadId}/savings_reports/{reportId}
     * @allow (create) User with UID 'user_abc' can create a savings report document under /leads/user_abc/.
     * @deny (create) User with UID 'user_def' cannot create a savings report document under /leads/user_abc/.
     * @allow (get, update, delete) User with UID 'user_abc' can get, update, and delete the savings report document under /leads/user_abc/.
     * @deny (get, update, delete) User with UID 'user_def' cannot get, update, or delete the savings report document under /leads/user_abc/.
     * @principle Restricts access to a user's own data tree. Validates relational integrity between documents.
     */
    match /leads/{leadId}/savings_reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

       function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.leadId == leadId;
      allow delete: if isExistingOwner(leadId);
    }

    /**
     * @description Controls access to the /leads/{leadId}/user_authentications/{authId} subcollection, restricting access to the lead owner.
     * @path /leads/{leadId}/user_authentications/{authId}
     * @allow (create) User with UID 'user_abc' can create a user authentication document under /leads/user_abc/.
     * @deny (create) User with UID 'user_def' cannot create a user authentication document under /leads/user_abc/.
     * @allow (get, update, delete) User with UID 'user_abc' can get, update, and delete the user authentication document under /leads/user_abc/.
     * @deny (get, update, delete) User with UID 'user_def' cannot get, update, or delete the user authentication document under /leads/user_abc/.
     * @principle Restricts access to a user's own data tree. Validates relational integrity between documents.
     */
    match /leads/{leadId}/user_authentications/{authId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return isSignedIn() && request.auth.uid == leadId;
      }

       function isExistingOwner(leadId) {
        return isOwner(leadId) && resource != null;
      }

      allow get: if isOwner(leadId);
      allow list: if isOwner(leadId);
      allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.leadId == leadId;
      allow delete: if isExistingOwner(leadId);
    }
  }
}
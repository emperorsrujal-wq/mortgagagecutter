/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for leads and their related data, ensuring that only authenticated users can access their own information.
 *
 * Data Structure:
 * - /leads/{leadId}: Stores lead information. The leadId is used as the document ID.
 * - /leads/{leadId}/mortgage_questionnaire_response/{responseId}: Stores mortgage questionnaire responses for a given lead.
 * - /leads/{leadId}/purchases/{purchaseId}: Stores purchase information for a given lead.
 * - /leads/{leadId}/savings_reports/{reportId}: Stores savings reports for a given lead.
 * - /leads/{leadId}/user_authentications/{authId}: Stores user authentication information for a given lead.
 *
 * Key Security Decisions:
 * - User-owned data: Only the authenticated user who owns a lead can access the lead's data and associated subcollections.
 * - Listing of leads: Listing all leads is explicitly denied to prevent unauthorized data access. If listing is required, implement an admin role and adjust the rules accordingly.
 * - Data Denormalization: The rules assume that the 'leadId' within the subcollection documents matches the {leadId} path parameter for efficient authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces access control for the /leads collection. Only the lead themselves can read/write their own lead document.
     * @path /leads/{leadId}
     * @allow (create) - Authenticated user creates their own lead document where request.auth.uid == leadId
     * @allow (get) - Authenticated user reads their own lead document where request.auth.uid == leadId
     * @allow (update) - Authenticated user updates their own lead document where request.auth.uid == leadId
     * @allow (delete) - Authenticated user deletes their own lead document where request.auth.uid == leadId
     * @deny (create) - Authenticated user tries to create a lead document with an ID that doesn't match their own UID
     * @deny (get) - Authenticated user tries to read a lead document that doesn't belong to them
     * @deny (update) - Authenticated user tries to update a lead document that doesn't belong to them
     * @deny (delete) - Authenticated user tries to delete a lead document that doesn't belong to them
     * @principle Enforces document ownership for writes.
     */
    match /leads/{leadId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isSignedIn() && isOwner(leadId) && resource != null;
      }

      // Allow creating a lead if the authenticated user's ID matches the leadId
      allow create: if isSignedIn() && isOwner(leadId) && request.resource.data.id == leadId;
      // Allow getting a lead if the authenticated user's ID matches the leadId
      allow get: if isSignedIn() && isOwner(leadId);
      // Allow updating a lead if the authenticated user's ID matches the leadId and the document exists
      allow update: if isExistingOwner(leadId) && resource.data.id == leadId;
      // Allow deleting a lead if the authenticated user's ID matches the leadId and the document exists
      allow delete: if isExistingOwner(leadId);
      // Prevent listing all leads
      allow list: if false;
    }

    /**
     * @description Enforces access control for the mortgage_questionnaire_response subcollection under a lead. Only the lead themselves can create, read, update, and delete responses.
     * @path /leads/{leadId}/mortgage_questionnaire_response/{responseId}
     * @allow (create) - Authenticated user creates a response under their lead document
     * @allow (get) - Authenticated user reads a response under their lead document
     * @allow (update) - Authenticated user updates a response under their lead document
     * @allow (delete) - Authenticated user deletes a response under their lead document
     * @deny (create) - Authenticated user tries to create a response under a lead document that doesn't belong to them
     * @deny (get) - Authenticated user tries to read a response under a lead document that doesn't belong to them
     * @deny (update) - Authenticated user tries to update a response under a lead document that doesn't belong to them
     * @deny (delete) - Authenticated user tries to delete a response under a lead document that doesn't belong to them
     * @principle Enforces document ownership for writes.
     */
    match /leads/{leadId}/mortgage_questionnaire_response/{responseId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isSignedIn() && isOwner(leadId) && resource != null;
      }

      // Allow creating a response if the authenticated user owns the lead
      allow create: if isSignedIn() && isOwner(leadId) && request.resource.data.leadId == leadId;
      // Allow getting a response if the authenticated user owns the lead
      allow get: if isSignedIn() && isOwner(leadId);
      // Allow updating a response if the authenticated user owns the lead and the document exists
      allow update: if isExistingOwner(leadId) && resource.data.leadId == leadId;
      // Allow deleting a response if the authenticated user owns the lead and the document exists
      allow delete: if isExistingOwner(leadId);
      // Allow listing responses if the authenticated user owns the lead
      allow list: if isSignedIn() && isOwner(leadId);
    }

    /**
     * @description Enforces access control for the purchases subcollection under a lead. Only the lead themselves can create, read, update, and delete purchases.
     * @path /leads/{leadId}/purchases/{purchaseId}
     * @allow (create) - Authenticated user creates a purchase under their lead document
     * @allow (get) - Authenticated user reads a purchase under their lead document
     * @allow (update) - Authenticated user updates a purchase under their lead document
     * @allow (delete) - Authenticated user deletes a purchase under their lead document
     * @deny (create) - Authenticated user tries to create a purchase under a lead document that doesn't belong to them
     * @deny (get) - Authenticated user tries to read a purchase under a lead document that doesn't belong to them
     * @deny (update) - Authenticated user tries to update a purchase under a lead document that doesn't belong to them
     * @deny (delete) - Authenticated user tries to delete a purchase under a lead document that doesn't belong to them
     * @principle Enforces document ownership for writes.
     */
    match /leads/{leadId}/purchases/{purchaseId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isSignedIn() && isOwner(leadId) && resource != null;
      }

      // Allow creating a purchase if the authenticated user owns the lead
      allow create: if isSignedIn() && isOwner(leadId) && request.resource.data.leadId == leadId;
      // Allow getting a purchase if the authenticated user owns the lead
      allow get: if isSignedIn() && isOwner(leadId);
      // Allow updating a purchase if the authenticated user owns the lead and the document exists
      allow update: if isExistingOwner(leadId) && resource.data.leadId == leadId;
      // Allow deleting a purchase if the authenticated user owns the lead and the document exists
      allow delete: if isExistingOwner(leadId);
      // Allow listing purchases if the authenticated user owns the lead
      allow list: if isSignedIn() && isOwner(leadId);
    }

    /**
     * @description Enforces access control for the savings_reports subcollection under a lead. Only the lead themselves can create, read, update, and delete reports.
     * @path /leads/{leadId}/savings_reports/{reportId}
     * @allow (create) - Authenticated user creates a report under their lead document
     * @allow (get) - Authenticated user reads a report under their lead document
     * @allow (update) - Authenticated user updates a report under their lead document
     * @allow (delete) - Authenticated user deletes a report under their lead document
     * @deny (create) - Authenticated user tries to create a report under a lead document that doesn't belong to them
     * @deny (get) - Authenticated user tries to read a report under a lead document that doesn't belong to them
     * @deny (update) - Authenticated user tries to update a report under a lead document that doesn't belong to them
     * @deny (delete) - Authenticated user tries to delete a report under a lead document that doesn't belong to them
     * @principle Enforces document ownership for writes.
     */
    match /leads/{leadId}/savings_reports/{reportId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isSignedIn() && isOwner(leadId) && resource != null;
      }

      // Allow creating a report if the authenticated user owns the lead
      allow create: if isSignedIn() && isOwner(leadId) && request.resource.data.leadId == leadId;
      // Allow getting a report if the authenticated user owns the lead
      allow get: if isSignedIn() && isOwner(leadId);
      // Allow updating a report if the authenticated user owns the lead and the document exists
      allow update: if isExistingOwner(leadId) && resource.data.leadId == leadId;
      // Allow deleting a report if the authenticated user owns the lead and the document exists
      allow delete: if isExistingOwner(leadId);
      // Allow listing reports if the authenticated user owns the lead
      allow list: if isSignedIn() && isOwner(leadId);
    }

    /**
     * @description Enforces access control for the user_authentications subcollection under a lead. Only the lead themselves can create, read, update, and delete authentications.
     * @path /leads/{leadId}/user_authentications/{authId}
     * @allow (create) - Authenticated user creates an authentication under their lead document
     * @allow (get) - Authenticated user reads an authentication under their lead document
     * @allow (update) - Authenticated user updates an authentication under their lead document
     * @allow (delete) - Authenticated user deletes an authentication under their lead document
     * @deny (create) - Authenticated user tries to create an authentication under a lead document that doesn't belong to them
     * @deny (get) - Authenticated user tries to read an authentication under a lead document that doesn't belong to them
     * @deny (update) - Authenticated user tries to update an authentication under a lead document that doesn't belong to them
     * @deny (delete) - Authenticated user tries to delete an authentication under a lead document that doesn't belong to them
     * @principle Enforces document ownership for writes.
     */
    match /leads/{leadId}/user_authentications/{authId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(leadId) {
        return request.auth.uid == leadId;
      }

      function isExistingOwner(leadId) {
        return isSignedIn() && isOwner(leadId) && resource != null;
      }

      // Allow creating an authentication if the authenticated user owns the lead
      allow create: if isSignedIn() && isOwner(leadId) && request.resource.data.leadId == leadId;
      // Allow getting an authentication if the authenticated user owns the lead
      allow get: if isSignedIn() && isOwner(leadId);
      // Allow updating an authentication if the authenticated user owns the lead and the document exists
      allow update: if isExistingOwner(leadId) && resource.data.leadId == leadId;
      // Allow deleting an authentication if the authenticated user owns the lead and the document exists
      allow delete: if isExistingOwner(leadId);
      // Allow listing authentications if the authenticated user owns the lead
      allow list: if isSignedIn() && isOwner(leadId);
    }
  }
}
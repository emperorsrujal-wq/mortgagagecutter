rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model. Access to sensitive lead data, 
     * mortgage profiles, savings projections, and purchase history is strictly limited 
     * to the authenticated user who owns that specific data tree.
     * 
     * DATA STRUCTURE
     * The database is organized hierarchically. All user-specific data is nested under 
     * the `/leads/{leadId}` collection, where {leadId} corresponds directly to the 
     * user's Firebase UID. This creates a natural security boundary.
     * 
     * KEY SECURITY DECISIONS
     * 1. Path-Based Authorization: We rely on the `{leadId}` path parameter matching 
     *    `request.auth.uid` as the primary authorization mechanism.
     * 2. Denormalization for Authorization: Essential fields like `leadId` (the owner's UID) 
     *    are required to be present on documents within subcollections. This allows 
     *    rules to verify ownership by checking the document content directly.
     * 3. Public Catalog: The `products` collection is marked as public-read to allow 
     *    unauthenticated users to browse the catalog, but writes are strictly prohibited.
     * 4. Relational Integrity: On creation, we enforce that the internal `leadId` field 
     *    matches the authenticated user's ID to prevent users from spoofing data for others.
     */

    // --- Helper Functions ---

    /** Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the authenticated user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root Lead document, identifying the user.
     * @path /leads/{leadId}
     * @allow (get) If the user is the owner.
     * @deny (list) If a user tries to list all leads.
     * @principle Ownership & Self-Creation.
     */
    match /leads/{leadId} {
      allow get: if isOwner(leadId);
      allow list: if false; // Users should not be able to list other leads.
      allow create: if isOwner(leadId) && request.resource.data.id == leadId;
      allow update: if isExistingOwner(leadId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(leadId);

      /**
       * @description Mortgage profile subcollection. Document ID is usually 'mortgageProfile'.
       * @path /leads/{leadId}/mortgageProfile/{profileId}
       * @allow (create) If leadId in path and data matches auth.uid.
       * @deny (update) If attempting to change the leadId owner field.
       * @principle Relational integrity and ownership.
       */
      match /mortgageProfile/{profileId} {
        allow get, list: if isOwner(leadId);
        allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
        allow update: if isExistingOwner(leadId) && request.resource.data.leadId == resource.data.leadId;
        allow delete: if isExistingOwner(leadId);
      }

      /**
       * @description Savings projection subcollection. Document ID is usually 'savingsProjection'.
       * @path /leads/{leadId}/savingsProjection/{projectionId}
       * @allow (get) If the user is the lead owner.
       * @principle Nested ownership.
       */
      match /savingsProjection/{projectionId} {
        allow get, list: if isOwner(leadId);
        allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
        allow update: if isExistingOwner(leadId) && request.resource.data.leadId == resource.data.leadId;
        allow delete: if isExistingOwner(leadId);
      }

      /**
       * @description Records of successful purchases made by the lead.
       * @path /leads/{leadId}/purchases/{purchaseId}
       * @allow (list) The lead can view their own purchase history.
       * @principle Ownership.
       */
      match /purchases/{purchaseId} {
        allow get, list: if isOwner(leadId);
        allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
        allow update: if isExistingOwner(leadId) && request.resource.data.leadId == resource.data.leadId;
        allow delete: if isExistingOwner(leadId);
      }

      /**
       * @description Grants of access to specific products/content.
       * @path /leads/{leadId}/accessGrants/{accessGrantId}
       * @allow (get) If the user is the lead owner.
       * @principle Ownership.
       */
      match /accessGrants/{accessGrantId} {
        allow get, list: if isOwner(leadId);
        allow create: if isOwner(leadId) && request.resource.data.leadId == leadId;
        allow update: if isExistingOwner(leadId) && request.resource.data.leadId == resource.data.leadId;
        allow delete: if isExistingOwner(leadId);
      }
    }

    /**
     * @description Public catalog of products.
     * @path /products/{productId}
     * @allow (get, list) For all users (unauthenticated browsing).
     * @deny (write) For all users (requires admin backend or manual entry).
     * @principle Public Read with Restricted Writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      
      // CRITICAL: Cannot implement owner-only writes. The 'Product' entity is missing an 'ownerId' or 'authorId' field.
      // In a production environment, these writes would likely be restricted to a 'manager' or 'admin' role.
      allow create, update, delete: if false; // TODO: Add administrative role check for product management.
    }

    /**
     * @description Mail collection for Firebase Trigger Email extension.
     * @path /mail/{mailId}
     * @allow (create) For any authenticated user. The extension processes these docs and sends emails.
     * @deny (read, update, delete) For all users. Only the backend extension should manage these.
     * @principle Restricted write-only queue for authenticated users.
     */
    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    /**
     * @description Email templates collection for Firebase Trigger Email extension.
     * @path /email_templates/{templateId}
     * @allow (get, list) For any authenticated user to read templates.
     * @deny (write) For all users. Templates are managed administratively.
     */
    match /email_templates/{templateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description User financial progress collection (Financial Academy).
     * @path /userFinancialProgress/{userId}
     * @principle Ownership.
     */
    match /userFinancialProgress/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

  }
}